// Secrets.xcconfig
// ─────────────────────────────────────────────────────────────
// NEVER commit this file to Git.
// Add it to .gitignore immediately after creating it in Xcode.
//
// How to use:
//   1. Add this file to your Xcode project (but NOT to any target)
//   2. In Xcode → Project → Info → Configurations:
//      set Debug and Release both to "Secrets"
//   3. In Info.plist add a new key:
//      GEMINI_API_KEY = $(GEMINI_API_KEY)
//   4. Read in Swift via Bundle.main.infoDictionary
// ─────────────────────────────────────────────────────────────

GEMINI_API_KEY = paste_your_key_here
