    "Reads important updates aloud, such as when a plant is added. Works alongside VoiceOver." : {
      "comment" : "A description of the accessibility settings.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liest wichtige Aktualisierungen vor, etwa wenn eine Pflanze hinzugefügt wird. Funktioniert zusammen mit VoiceOver."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lee en voz alta las actualizaciones importantes, como cuando se añade una planta. Funciona junto con VoiceOver."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Binabasa nang malakas ang mahahalagang update, gaya ng kapag may naidagdag na halaman. Gumagana kasama ang VoiceOver."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lit à voix haute les mises à jour importantes, par exemple lorsqu'une plante est ajoutée. Fonctionne avec VoiceOver."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Membacakan pembaruan penting, seperti saat tanaman ditambahkan. Berfungsi bersama VoiceOver."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Legge ad alta voce gli aggiornamenti importanti, ad esempio quando viene aggiunta una pianta. Funziona insieme a VoiceOver."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "植物が追加されたときなど、重要な更新を音声で読み上げます。VoiceOverと併用できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "식물이 추가될 때와 같은 중요한 업데이트를 소리 내어 읽어줍니다. VoiceOver와 함께 작동합니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Membacakan kemas kini penting, seperti apabila tumbuhan ditambah. Berfungsi bersama VoiceOver."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Озвучивает важные обновления, например, когда добавлено растение. Работает вместе с VoiceOver."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "อ่านออกเสียงการอัปเดตที่สำคัญ เช่น เมื่อมีการเพิ่มต้นไม้ ทำงานร่วมกับ VoiceOver"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Đọc to các cập nhật quan trọng, chẳng hạn như khi một cây được thêm vào. Hoạt động cùng với VoiceOver."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "朗读重要更新，例如添加植物时。可与旁白功能配合使用。"
          }
        }
      }
    },
