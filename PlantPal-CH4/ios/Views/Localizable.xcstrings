    "This removes %@ and its check-in history. This can't be undone." : {
      "comment" : "A confirmation dialog that lets the user delete a plant. The argument is the nickname of the plant to be deleted.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden %@ und der zugehörige Überprüfungsverlauf entfernt. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará %@ y su historial de revisiones. Esta acción no se puede deshacer."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aalisin nito si %@ at ang history ng check-in nito. Hindi na ito puwedeng bawiin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprimera %@ et son historique de contrôles. Cette action est irréversible."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ini akan menghapus %@ beserta riwayat pemeriksaannya. Tindakan ini tidak dapat dibatalkan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa azione rimuoverà %@ e la sua cronologia dei controlli. Non può essere annullata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これにより%@とそのチェック履歴が削除されます。この操作は元に戻せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 작업은 %@과(와) 체크인 기록을 삭제합니다. 이 작업은 되돌릴 수 없습니다."
          }
        },
        "ms" : {
          "stringUnit" : {
