    "One sensor works for every plant. Pair it once, then move it next to whichever plant you want to check." : {
      "comment" : "A description of the device pairing process.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Sensor funktioniert für jede Pflanze. Koppele ihn einmal und bewege ihn dann zu der Pflanze, die du überprüfen möchtest."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un solo sensor funciona para todas las plantas. Empárejalo una vez y luego acércalo a la planta que quieras revisar."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isang sensor lang ang kailangan para sa lahat ng halaman. I-pair ito nang isang beses, pagkatapos ilapit sa kahit anong halaman na gusto mong suriin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un seul capteur fonctionne pour toutes les plantes. Appairez-le une fois, puis rapprochez-le de la plante que vous souhaitez vérifier."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Satu sensor bisa digunakan untuk semua tanaman. Pasangkan sekali, lalu pindahkan ke tanaman mana pun yang ingin kamu periksa."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un solo sensore funziona per tutte le piante. Associalo una volta, poi spostalo vicino alla pianta che vuoi controllare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1つのセンサーですべての植物に対応できます。一度ペアリングしたら、チェックしたい植物の近くに移動させてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "센서 하나로 모든 식물을 관리할 수 있어요. 한 번만 페어링하면, 확인하고 싶은 식물 옆으로 옮기기만 하면 됩니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Satu penderia berfungsi untuk semua tumbuhan. Pasangkan sekali, kemudian alihkan ke mana-mana tumbuhan yang anda mahu semak."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Один датчик подходит для всех растений. Подключите его один раз, а затем переносите к тому растению, которое хотите проверить."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เซนเซอร์ตัวเดียวใช้ได้กับทุกต้นไม้ จับคู่เพียงครั้งเดียว จากนั้นย้ายไปไว้ใกล้ต้นไม้ที่คุณต้องการตรวจสอบ"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Một cảm biến dùng được cho mọi cây. Ghép nối một lần, sau đó di chuyển đến gần cây bất kỳ mà bạn muốn kiểm tra."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一个传感器可用于所有植物。只需配对一次，然后把它移到你想检查的植物旁边即可。"
          }
        }
      }
    },
