    "Waiting for the sensor to join \"%@\". Use a 2.4 GHz Wi-Fi network, not the sensor's own PlantPal access point." : {
      "comment" : "A message instructing the user to connect their plant sensor to a specific Wi-Fi network. The placeholder text inside the double-quotes should be replaced with the SSID of the network the sensor will connect to. The argument is the string “”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Warten darauf, dass sich der Sensor mit „%@“ verbindet. Verwende ein 2,4-GHz-WLAN-Netzwerk, nicht den eigenen PlantPal-Zugangspunkt des Sensors."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esperando a que el sensor se una a «%@». Usa una red Wi-Fi de 2,4 GHz, no el propio punto de acceso PlantPal del sensor."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hinihintay na sumali ang sensor sa “%@”. Gumamit ng 2.4 GHz na Wi-Fi network, hindi ang sarili nitong PlantPal access point."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En attente que le capteur rejoigne « %@ ». Utilisez un réseau Wi-Fi 2,4 GHz, pas le propre point d'accès PlantPal du capteur."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Menunggu sensor bergabung dengan “%@”. Gunakan jaringan Wi-Fi 2,4 GHz, bukan access point PlantPal milik sensor sendiri."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In attesa che il sensore si connetta a «%@». Usa una rete Wi-Fi a 2,4 GHz, non il punto di accesso PlantPal del sensore stesso."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "センサーが「%@」に接続するのを待っています。センサー自体のPlantPalアクセスポイントではなく、2.4GHzのWi-Fiネットワークを使用してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "센서가 “%@”에 연결될 때까지 기다리는 중입니다. 센서 자체의 PlantPal 액세스 포인트가 아닌 2.4GHz Wi-Fi 네트워크를 사용하세요."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Menunggu penderia menyertai “%@”. Gunakan rangkaian Wi-Fi 2.4 GHz, bukan titik akses PlantPal milik penderia sendiri."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ожидание подключения датчика к «%@». Используйте сеть Wi-Fi 2,4 ГГц, а не собственную точку доступа PlantPal датчика."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "กำลังรอให้เซนเซอร์เชื่อมต่อกับ “%@” ใช้เครือข่าย Wi-Fi ความถี่ 2.4 GHz ไม่ใช่จุดเชื่อมต่อ PlantPal ของเซนเซอร์เอง"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Đang chờ cảm biến tham gia vào “%@”. Hãy dùng mạng Wi-Fi 2,4 GHz, không phải điểm truy cập PlantPal riêng của cảm biến."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
