    "Add your first plant to begin monitoring its health." : {
      "comment" : "A description of the benefits of adding a plant.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Füge deine erste Pflanze hinzu, um ihre Gesundheit zu überwachen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade tu primera planta para empezar a monitorear su salud."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
